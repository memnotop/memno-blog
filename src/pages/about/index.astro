---
import { Content, frontmatter, getHeadings } from '../../data/pages/about.mdx'
import PageLayout from '@/layouts/CommonPage.astro'

const headings = getHeadings()
---

<PageLayout title={frontmatter.title} {headings} comment>
  {frontmatter.subtitle && <p class='text-muted-foreground'>{frontmatter.subtitle}</p>}
  <Content />
</PageLayout>
