---
import type { CollectionKey, InferEntrySchema } from 'astro:content'
import config from 'virtual:config'

import { QRCode } from 'astro-pure/advanced'
import { Icon } from 'astro-pure/user'

interface Props<T extends CollectionKey> {
  data: InferEntrySchema<T>
  class?: string
}

const { data, class: className } = Astro.props
const { title, publishDate } = data
const wrapperClass = ['space-y-2', className].filter(Boolean).join(' ')
const formattedPublishDate = publishDate
  ? new Intl.DateTimeFormat(config.locale.dateLocale, {
      ...config.locale.dateOptions,
      month: 'long'
    }).format(publishDate)
  : ''
---

<section class={wrapperClass}>
  <div class='flex items-center gap-2'>
    <span class='grid size-5 place-items-center rounded-sm border border-border bg-muted'>
      <span class='size-2 rounded-[2px] bg-foreground/70'></span>
    </span>
    <h2 class='text-xl font-semibold text-foreground sm:text-2xl'>分享</h2>
    <span class='h-px min-w-8 flex-1 bg-border'></span>
    <span class='size-3 rounded-[2px] border border-border bg-background'></span>
    <span class='size-2 rounded-[2px] border border-border bg-muted'></span>
  </div>

  <div class='relative flex flex-col gap-y-3 rounded-xl border px-3 py-2 sm:px-4 sm:py-3'>
    <Icon class='absolute end-4 top-4 size-20 opacity-10' name='copyright' />

    <div class='font-medium text-foreground'>{title}</div>

    <div class='flex flex-row flex-wrap justify-start gap-x-5 gap-y-1 sm:gap-x-8'>
      <div class='flex gap-x-2 sm:flex-col'>
        <span>Author</span>
        <span class='text-sm text-foreground max-sm:place-self-center'>{config.author}</span>
      </div>
      {
        publishDate && (
          <div class='flex gap-x-2 sm:min-w-16 sm:flex-col'>
            <span>Published at</span>
            <span class='text-sm text-foreground max-sm:place-self-center'>
              {formattedPublishDate}
            </span>
          </div>
        )
      }
      <div class='flex gap-x-2 sm:flex-col'>
        <span>Copyright</span>
        <a
          class='text-sm text-foreground max-sm:place-self-center'
          href='https://creativecommons.org/licenses/by-nc-sa/4.0/'
          target='_blank'
        >
          CC BY-NC-SA 4.0
        </a>
      </div>
    </div>

    <div class='relative'>
      <div class='flex flex-row gap-3'>
        <button
          id='copy-link'
          class='group inline-flex items-center gap-1.5 rounded-full bg-muted px-2 py-1 text-sm text-muted-foreground transition-colors hover:text-primary sm:px-2.5 sm:py-1.5'
        >
          <Icon class='size-5' name='link' />
          <span>复制链接</span>
        </button>
        <button
          id='get-qrcode'
          class='group rounded-full bg-muted p-1 text-muted-foreground transition-colors hover:text-primary sm:p-1.5'
          aria-label='QRCode'
        >
          <Icon class='size-5' name='qrcode' />
        </button>
      </div>
      <QRCode
        class='absolute z-10 -mt-2 box-content max-h-0 max-w-44 overflow-hidden rounded-xl border bg-muted p-4 opacity-0 transition-all duration-300 ease-in-out'
      />
    </div>
  </div>
</section>

<style>
  #qrcode-container.expanded {
    max-height: 11rem;
    transform: translateY(4px);
    opacity: 100;
  }
</style>

<script>
  const copyLink = document.getElementById('copy-link')
  copyLink?.addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href)
    document.dispatchEvent(new CustomEvent('toast', { detail: { message: '链接已复制' } }))
  })

  const getQRCode = document.getElementById('get-qrcode')
  const qrcodeContainer = document.getElementById('qrcode-container')
  getQRCode?.addEventListener('click', () => qrcodeContainer?.classList.toggle('expanded'))
</script>
